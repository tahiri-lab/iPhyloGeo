{
  "name": "iphylogeo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "node scripts/sass_css.js",
    "watch:css": "node scripts/sass_css.js --watch",
    "watch:locales": "chokidar \"apps/locales/**/*.json\" -c \"node scripts/touch_app_on_locale_change.js\"",
    "dev:assets": "concurrently --raw --kill-others \"npm run --silent watch:css\" \"npm run --silent watch:locales\"",
    "worker:rq": "python -m rq.cli worker default --url redis://localhost:6379/0",
    "start": "concurrently --raw --kill-others \"python apps/app.py\" \"cross-env GTK_IM_MODULE=xim electron main.js\" \"npm run --silent dev:assets\" \"npm run --silent worker:rq\"",
    "server": "concurrently --raw --kill-others \"python apps/app.py\" \"npm run --silent dev:assets\" \"npm run --silent worker:rq\"",
    "lint": "flake8 apps",
    "test": "python -m pytest",
    "test:unit": "python -m pytest tests/unit -m unit",
    "test:integration": "python -m pytest tests/integration -m integration",
    "test:e2e": "python -m pytest tests/e2e -m e2e"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.1.2",
    "cytoscape-panzoom": "^2.5.3"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "electron": "^41.1.1",
    "sass": "^1.97.2"
  }
}
